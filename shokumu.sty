% 上下左右の空白を調整
\usepackage[left=20mm,right=20mm,top=20mm,bottom=30mm]{geometry}

% 著者名を右寄せにする
% 参考: https://oku.edu.mie-u.ac.jp/~okumura/texfaq/qa/25838.html
\makeatletter
  \def\@maketitle{%
  \newpage\null
  \vskip 2em%
  \begin{center}%
  \let\footnote\thanks
    {\LARGE \@title \par}%
    \vskip 1.5em%
  \end{center}% 追加
    \mbox{}\hfill%% 追加
    {
      \lineskip .5em%
      \begin{tabular}[t]{r}%
        {\Large \@author} \\
        \@date \\
      \end{tabular}\par}%
  \par\vskip 1.5em}
\makeatother
